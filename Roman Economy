    print("✓ Matches archaeological evidence: coins, local pottery, prosperity")
    print("="*60 + "\n")
    
    # Create visualizations
    fig1 = economy.plot_comparison(p1_results, p2_results)
    fig2 = economy.plot_labor_market()
    
    plt.show()

